\":9,\"priorityAndColour\":[{\"badgeId\":\"STORESPECIAL\",\"colorId\":\"pricing-dark\",\"badgeLabel\":\"Store Special\",\"priority\":1},{\"badgeId\":\"Taxable\",\"colorId\":\"discontinued\",\"badgeLabel\":\"Taxable\",\"priority\":2},{\"badgeId\":\"OI\",\"colorId\":\"availability-light\",\"badgeLabel\":\"Factory Installed\",\"priority\":3},{\"badgeId\":\"OI-front\",\"colorId\":\"availability-light\",\"badgeLabel\":\"Factory Installed\",\"priority\":4},{\"badgeId\":\"OI-rear\",\"colorId\":\"availability-light\",\"badgeLabel\":\"Factory Installed\",\"priority\":5},{\"badgeUrl\":\"/en/promotions/clearance.html\",\"badgeId\":\"CLEARANCE\",\"colorId\":\"availability-dark\",\"badgeLabel\":\"Clearance\u25ca\",\"priority\":6,\"disclaimer\":\"*On select style/sizes\"},{\"badgeId\":\"INSTANTREBATE\",\"colorId\":\"pricing-light\",\"badgeLabel\":\"Instant Rebate\",\"priority\":7},{\"badgeId\":\"MAILINREBATE\",\"colorId\":\"pricing-light\",\"badgeLabel\":\"Mail-in Rebate\",\"priority\":8},{\"badgeId\":\"LOYALTY\",\"colorId\":\"pricing-light\",\"badgeLabel\":\"Bonus CT Money\u00ae\",\"priority\":9},{\"badgeUrl\":\"/en/promotions/hot-sale.html\",\"badgeId\":\"PROMO\",\"colorId\":\"pricing-dark\",\"badgeLabel\":\"Sale\",\"priority\":10},{\"badgeId\":\"BESTSELLER\",\"colorId\":\"recommendation-light\",\"badgeLabel\":\"Best Seller\",\"priority\":11},{\"badgeId\":\"TOPRATED\",\"colorId\":\"recommendation-light\",\"badgeLabel\":\"Top Rated\",\"priority\":12},{\"badgeId\":\"EXCLUSIVE\",\"colorId\":\"availability-light\",\"badgeLabel\":\"Exclusive\",\"priority\":13},{\"badgeId\":\"LIMITEDTIMEOFFER\",\"colorId\":\"pricing-light\",\"badgeLabel\":\"Limited Time Offer\",\"priority\":14},{\"badgeUrl\":\"/en/promotions/hot-sale.html\",\"badgeId\":\"HOTDEAL\",\"colorId\":\"pricing-dark\",\"badgeLabel\":\"Hot Deal\",\"priority\":15},{\"badgeId\":\"ROADRATED\",\"colorId\":\"recommendation-light\",\"badgeLabel\":\"Road Rated\",\"priority\":16},{\"badgeId\":\"PERFECTGIFT\",\"colorId\":\"recommendati