\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_YT_AWAR_COM_CAN_TRM_6sec_BRAND-6S',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_YT_AWAR_COM_CAN_TRM_6sec_GAB-6S',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_YT_AWAR_COM_CAN_TRM_15sec_BRAND-15S-CURL',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_YT_AWAR_COM_CAN_TRM_15sec_BRAND-15S-SLED',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_YT_AWAR_COM_CAN_TRM_30sec_BRAND-30S',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_YT_AWAR_COM_CAN_TRM_6sec_BRAND-6S',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_YT_AWAR_COM_CAN_TRM_6sec_GAB-6S',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_YT_AWAR_COM_CAN_TRV_30sec_BRAND-30S',\\n\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_NFX_AWAR_PG_CAN_VID_30sec_BRAND-30S-FI',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_NFX_AWAR_PG_CAN_VID_30sec_BRAND-30S-ROS',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_NFX_AWAR_PG_CAN_VID_15sec_BRAND-15S-CURL',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_NFX_AWAR_PG_CAN_VID_15sec_BRAND-15S-SLED',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_NFX_AWAR_PG_CAN_VID_30sec_BRAND-30S-FI',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_NFX_AWAR_PG_CAN_VID_30sec_BRAND-30S-ROS',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_NFX_AWAR_PG_CAN_VID_15sec_BRAND-15S-CURL',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_NFX_AWAR_PG_CAN_VID_15sec_BRAND-15S-SLED',\\n\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_SNT_AWAR_PG_CAN_VID_15sec_BRAND-15S-CURL',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_SNT_AWAR_PG_CAN_VID_15sec_BRAND-15S-SLED',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_SNT_AWAR_PG_CAN_VID_15sec_BRAND-30S',\\n\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_CBC_AWAR_DB_CAN_VID_30sec_BRAND-15S-CURL',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_CBC_AWAR_DB_CAN_VID_15sec_BRAND-15S-SLED',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_EN_CBC_AWAR_DB_CAN_VID_15sec_BRAND-30S',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_CBC_AWAR_DB_CAN_VID_30sec_BRAND-15S-CURL',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_CBC_AWAR_DB_CAN_VID_15sec_BRAND-15S-SLED',\\n                        'utm_content=M2621226_26_CTS_OLY_WINTER-OLYMPICS_FR_CBC_AWAR_DB_CAN_VID_15sec_BRAND-30S',\\n                        'OLYMPICS_PARTNER'\\n                    ];\\n\\n                    const markSession = function() {\\n                        utils.setProfileAttribute('olympicUser', 'true');\\n                        window.localStorage.setItem('abtres_olympicUser', 'true');\\n                    };\\n\\n                    const isOlympicSession = urlPartsToMark.some(function(urlSubString) {\\n                        return urlLowerCase.indexOf(urlSubString.toLowerCase()) > -1;\\n                    });\\n\\n                    if (isOlympicSession) {\\n                        markSession();\\n                    }\\n                } catch (error) {\\n                    console.log('[Target]: Error occurs while marking the Olympic session in Target: ' + error);\\n                }\\n            };\\n\\n            if (window.ab_test_utils) {\\n                init(window.ab_test_utils);\\n            } else {\\n                const utilsInterval = setInterval(() => {\\n                    clearInterval(utilsInterval);\\n                    init(window.ab_test_utils);\\n                }, 100);\\n            }\\n        })();\\n    </script>\\n</div>\",\"selector\":\"BODY > *:eq(0)\",\"prehidingSelector\":\"\"}}]},{\"id\":\"AT:eyJhY3Rpdml0eUlkIjoiMTY2ODgyOSIsImV4cGVyaWVuY2VJZCI6IjAifQ==\",\"scope\":\"__view__\",\"scopeDetails\":{\"decisionProvider\":\"TGT\",\"activity\":{\"id\":\"1668829\"},\"experience\":{\"id\":\"0\"},\"strategies\":[{\"step\":\"entry\",\"trafficType\":\"0\"},{\"step\":\"display\",\"trafficType\":\"0\"},{\"step\":\"conversion\",\"trafficType\":\"0\"}],\"characteristics\":{\"eventToken\":\"CDH42A00P+uLwXOl4kWtHnZJRFNRMCdc84hKiEgfaartyf8vZbHfLICMmcVo4KgxeFPWmOXlYBUkzsy7MEHUnWnlssGfqtZmAiSO52NWERc=\"},\"correlationID\":\"1668829:0:0\"},\"items\":[{\"id\":\"1668829-5\",\"schema\":\"https://ns.adobe.com/personalization/dom-action\",\"meta\":{\"experience.id\":\"0\",\"activity.name\":\"__PJS: AB: screen width info\",\"profile.category_parents_parent\":\"\",\"geo.city\":\"santa clara\",\"activity.id\":\"1668829\",\"geo.state\":\"california\",\"experience.name\":\"Experience A\",\"geo.zip\":\"95054\",\"profile.Category_Level3_or_2\":\"\",\"profile.Test_Category_Parents\":\"\",\"geo.country\":\"united states\",\"offer.name\":\"Default Content\",\"geo.dma\":\"san francisco-oak-san jose\",\"profile.currentcategory\":\"\",\"offer.id\":\"0\"},\"data\":{\"type\":\"customCode\",\"format\":\"application/vnd.adobe.target.dom-action\",\"content\":\"<script>\\n    (function() {\\n        const utilsInterval = setInterval(() => {\\n            if (window.ab_test_utils) {\\n                clearInterval(utilsInterval);\\n                window.ab_test_utils.waitForWindowObject('alloy').then(function(alloy) {\\n                    alloy(\\\"sendEvent\\\", {\\n                        \\\"renderDecisions\\\": false,\\n                        \\\"xdm\\\": {\\n                            \\\"eventType\\\": \\\"custom.setAbTestProfileAttribute\\\"\\n                        },\\n                        \\\"data\\\": {\\n                            \\\"__adobe\\\": {\\n                                \\\"target\\\": {\\n                                    \\\"profile.abtest.screenWidth\\\": window.innerWidth\\n                                }\\n                            }\\n                        },\\n                        \\\"decisionScopes\\\": [\\\"__view__\\\"]\\n                    }).then(function() {\\n                        console.log('[AB Test Utils]: Setting Profile attribute profile.abtest.screenWidth to ', window.innerWidth);\\n                        window.ab_test_utils.activateActivityByTargetType('callback_screenWidth', 'Prod', 'CTR');\\n                    });\\n                });\\n            }\\n        }, 100);\\n    })();\\n</script>\",\"selector\":\"BODY > *:eq(0)\",\"prehidingSelector\":\"\"}}]},{\"id\":\"AT:eyJhY3Rpdml0eUlkIjoiMTY2MzE3MiIsImV4cGVyaWVuY2VJZCI6IjAifQ==\",\"scope\":\"__view__\",\"scopeDetails\":{\"decisionProvider\":\"TGT\",\"activity\":{\"id\":\"1663172\"},\"experience\":{\"id\":\"0\"},\"strategies\":[{\"step\":\"entry\",\"trafficType\":\"0\"},{\"step\":\"display\",\"trafficType\":\"0\"},{\"step\":\"conversion\",\"trafficType\":\"0\"}],\"characteristics\":{\"eventToken\":\"KrITrOgRRIrWZvVy23xdpHZJRFNRMCdc84hKiEgfaartyf8vZbHfLICMmcVo4KgxzDykkfClSNvchmZ44G3lV2nlssGfqtZmAiSO52NWERc=\"},\"correlationID\":\"1663172:0:0\"},\"items\":[{\"id\":\"1663172-3\",\"schema\":\"https://ns.adobe.com/personalization/dom-action\",\"meta\":{\"experience.id\":\"0\",\"activity.name\":\"__PJS: AB: ATC Tracking\",\"profile.category_parents_parent\":\"\",\"geo.city\":\"santa clara\",\"activity.id\":\"1663172\",\"geo.state\":\"california\",\"experience.name\":\"Experience A\",\"geo.zip\":\"95054\",\"profile.Category_Level3_or_2\":\"\",\"profile.Test_Category_Parents\":\"\",\"geo.country\":\"united states\",\"offer.name\":\"Default Content\",\"geo.dma\":\"san francisco-oak-san jose\",\"profile.currentcategory\":\"\",\"offer.id\":\"0\"},\"data\":{\"type\":\"customCode\",\"format\":\"application/vnd.adobe.target.dom-action\",\"content\":\"<div class=\\\"ab-test-project-js-track-atc\\\">\\n    <script>\\n        (function(){\\n            const init = function (utils, $) {\\n                const $body = $('body');\\n                const basePlpTileClickEventName = 'ab_plp_tile_click';\\n                const baseAtcEventName = 'ab_atc_success';\\n                const baseAtcMboxName = 'ab_atc_success_mbox';\\n                const baseBuyNowEventName = 'ab_buy_now_click';\\n                const atcTypes = { // can be 'split' by delivery types\\n                    pdp: 'pdp', // includes only pdp ATC buttons excludes carousels\\n                    plp: 'plp', // includes only plp ATC tile buttons excludes carousels\\n                    flyer: 'flyer', // flyer ATC flow\\n                    carousel: 'carousel' // includes only carousels ATC buttons on any page including plp, pdp, etc.\\n                };\\n                const atcDeliveryTypes = {\\n                    fbt: 'fbt',\\n                    directTile: 'direct_tile',\\n                    bopis: 'bopis',\\n                    express: 'express',\\n                    sth: 'sth'\\n                };\\n                const productTypes = {\\n                    gen: 'gen',\\n                    tire: 'tire',\\n                    wheel: 'wheel',\\n                    autoPart: 'auto-part',\\n                    na: 'na'\\n                };\\n                const productSaleClearanceTypes = {\\n                    sale: 'sale',\\n                    clearance: 'clearance',\\n                    regular: 'regular',\\n                    na: 'na'\\n                };\\n                let alreadyListenToMiniPdpAtc = false;\\n                let lastClickedQLFrom;\\n\\n                const callIfIsTrusted = function (callback, event) {\\n                    if (event && event.originalEvent && event.originalEvent.isTrusted && typeof callback === 'function') {\\n                        callback(event);\\n                    }\\n                };\\n                const confirmAtcSendEvent = function (atcConfirmElemCssClass, atcType, atcDeliveryType, productType, productSaleClearance) {\\n                    utils.waitForElement('.' + atcConfirmElemCssClass + ',.nl-toast__error-container').then(function(el) {\\n                        if ($(el).hasClass(atcConfirmElemCssClass)) {\\n                            utils.sendCustomMboxEvent(baseAtcEventName, {\\n                                atcType: atcType,\\n                                atcDeliveryType: atcDeliveryType,\\n                                productType: productType,\\n                                productSaleClearance: productSaleClearance\\n                            });\\n                            utils.sendCustomMboxEvent(baseAtcEventName, {\\n                                atcType: atcType,\\n                                atcDeliveryType: atcDeliveryType,\\n                                productType: productType,\\n                                productSaleClearance: productSaleClearance\\n                            }, baseAtcMboxName);\\n                        }\\n                    });\\n                };\\n                const getTileAtcButtonType = function ($target) {\\n                    const $atcBtn = $target.hasClass('nl-product-card__atc-button') ? $target : $target.closest('.nl-product-card__atc-button');\\n                    if ($atcBtn.find('.nl-icon-ct-cart').length > 0) {\\n                        return 'direct-atc';\\n                    }\\n                    if ($atcBtn.hasClass('nl-product-card__atc-button--quick-look')) {\\n                        return 'quicklook';\\n                    }\\n                    return 'options';\\n                };\\n                const getDeliveryTypeOnByuboxOrMiniPdpAtc = function ($target) {\\n                    const $deliveryTypeIcon = $target.attr('id') === 'add-to-cart-sticky-buy-bar'\\n                        ? $('.nl-buy-box .nl-buy-online__list-item.nl-buy-online__list-item--selected svg.nl-icon')\\n                        : $target\\n                            .closest('.minipdp,.buybox')\\n                            .find('.nl-buy-online__list-item.nl-buy-online__list-item--selected svg.nl-icon');\\n                    return ($deliveryTypeIcon.hasClass('nl-icon-ct-default-ship-to-home') || $deliveryTypeIcon.hasClass('nl-icon-sc-default-ship-to-home') || $deliveryTypeIcon.hasClass('nl-icon-mr-default-ship-to-home'))\\n                        ? atcDeliveryTypes.sth\\n                        : ($deliveryTypeIcon.hasClass('nl-icon-ct-store-pick-up') || $deliveryTypeIcon.hasClass('nl-icon-sc-store-pick-up') || $deliveryTypeIcon.hasClass('nl-icon-mr-store-pick-up'))\\n                            ? atcDeliveryTypes.bopis\\n                            : ($deliveryTypeIcon.hasClass('nl-icon-ct-express-delivery') || $deliveryTypeIcon.hasClass('nl-icon-sc-express-delivery') || $deliveryTypeIcon.hasClass('nl-icon-mr-express-delivery'))\\n                                ? atcDeliveryTypes.express\\n                                : undefined;\\n                };\\n                const getPlpProductType = function () {\\n                    const url = window.location.href;\\n                    if (url.indexOf('/fr/cat/automobile/pneus-et-jantes/pneus') > -1 || url.indexOf('/en/cat/automotive/tires-wheels/tires') > -1) {\\n                        return productTypes.tire;\\n                    }\\n                    if (url.indexOf('/fr/cat/automobile/pneus-et-jantes/jantes') > -1 || url.indexOf('/en/cat/automotive/tires-wheels/wheels') > -1) {\\n                        return productTypes.wheel;\\n                    }\\n                    if (url.indexOf('/fr/cat/automobile') > -1 || url.indexOf('/en/cat/automotive') > -1) {\\n                        return productTypes.autoPart;\\n                    }\\n                    return productTypes.gen;\\n                };\\n                const getPdpMiniPdpProductSaleClearance = function (event) {\\n                    const targetId = $(event.target).attr('id');\\n                    const $targetProduct = (targetId === 'add-to-cart-sticky-buy-bar' || targetId === 'buy-now' || targetId === 'addToCartBtn')\\n                        ? $('.buybox')\\n                        : $(event.target).closest('.nl-product__content,.minipdp,.buybox');\\n                    if ($targetProduct.find('.nl-tag.nl-tag--product.nl-tag--product--availability-dark').length > 0) {\\n                        return productSaleClearanceTypes.clearance;\\n                    } else if ($targetProduct.find('.nl-tag.nl-tag--product.nl-tag--product--pricing-dark').length > 0) {\\n                        return productSaleClearanceTypes.sale;\\n                    } else {\\n                        return productSaleClearanceTypes.regular;\\n                    }\\n                };\\n                const getPlpTileSaleClearanceType = function (event) {\\n                    const $targetTile = $(event.target).closest('.nl-product__content,.nl-product-card__content');\\n                    if ($targetTile.find('.nl-tag.nl-tag--product.nl-tag--product--availability-dark').length > 0) {\\n                        return productSaleClearanceTypes.clearance;\\n                    } else if ($targetTile.find('.nl-tag.nl-tag--product.nl-tag--product--pricing-dark').length > 0) {\\n                        return productSaleClearanceTypes.sale;\\n                    } else {\\n                        return productSaleClearanceTypes.regular;\\n                    }\\n                };\\n                const onPlpMiniPdpAtcClick = function (event) {\\n                    const productType = lastClickedQLFrom === atcTypes.plp ? getPlpProductType() : productTypes.na;\\n                    confirmAtcSendEvent(\\n                        'nl-toast__success-container',\\n                        lastClickedQLFrom,\\n                        getDeliveryTypeOnByuboxOrMiniPdpAtc($(event.target)),\\n                        productType,\\n                        getPdpMiniPdpProductSaleClearance(event)\\n                    );\\n                };\\n                const onPlpOrCarouselTileAtcButtonClick = function (atcType, event) {\\n                    const interactedAtcElem = getTileAtcButtonType($(event.target));\\n                    if (interactedAtcElem === 'direct-atc') {\\n                        const productType = atcType === atcTypes.plp ? getPlpProductType() : productTypes.na;\\n                        confirmAtcSendEvent(\\n                            'nl-toast__success-container',\\n                            atcType,\\n                            atcDeliveryTypes.directTile,\\n                            productType,\\n                            getPlpTileSaleClearanceType(event)\\n                        );\\n                    }\\n                    if (interactedAtcElem === 'quicklook') {\\n                        lastClickedQLFrom = atcType;\\n                        if (!alreadyListenToMiniPdpAtc) {\\n                            alreadyListenToMiniPdpAtc = true;\\n                            $body.on('click', '.minipdp #add-to-cart', callIfIsTrusted.bind(this, onPlpMiniPdpAtcClick));\\n                        }\\n                    }\\n                };\\n                const productHandler = function () {\\n                    const getPdpProductType = function () {\\n                        const $tiresBcLink = $('.nl-breadcrumbs__link[href=\\\"/fr/cat/automobile/pneus-et-jantes/pneus-DC0002726.html\\\"],.nl-breadcrumbs__link[href=\\\"/en/cat/automotive/tires-wheels/tires-DC0002726.html\\\"]');\\n                        const $wheelsBcLink = $('.nl-breadcrumbs__link[href=\\\"/fr/cat/automobile/pneus-et-jantes/jantes-DC0002727.html\\\"],.nl-breadcrumbs__link[href=\\\"/en/cat/automotive/tires-wheels/wheels-DC0002727.html\\\"]');\\n                        const $autoBcLink = $('.nl-breadcrumbs__link[href=\\\"/fr/cat/automobile-DC0000006.html\\\"],.nl-breadcrumbs__link[href=\\\"/en/cat/automotive-DC0000006.html\\\"]');\\n                        if ($tiresBcLink.length > 0) {\\n                            return productTypes.tire;\\n                        }\\n                        if ($wheelsBcLink.length > 0) {\\n                            return productTypes.wheel;\\n                        }\\n                        if ($autoBcLink.length > 0) {\\n                            return productTypes.autoPart;\\n                        }\\n                        return productTypes.gen;\\n                    };\\n\\n                    const onPdpAtcClick = function (event) {\\n                        confirmAtcSendEvent(\\n                            'nl-cart-flyout__container',\\n                            atcTypes.pdp,\\n                            getDeliveryTypeOnByuboxOrMiniPdpAtc($(event.target)),\\n                            getPdpProductType(),\\n                            getPdpMiniPdpProductSaleClearance(event)\\n                        );\\n                    };\\n                    const onFbtAtcClick = function (event) {\\n                        confirmAtcSendEvent(\\n                            'nl-cart-flyout__container',\\n                            atcTypes.pdp,\\n                            atcDeliveryTypes.fbt,\\n                            getPdpProductType(),\\n                            getPdpMiniPdpProductSaleClearance(event)\\n                        );\\n                    };\\n                    const onPdpBuyNowClick = function (event) {\\n                        utils.sendCustomMboxEvent(baseBuyNowEventName, {\\n                            atcType: atcTypes.pdp,\\n                            atcDeliveryType: getDeliveryTypeOnByuboxOrMiniPdpAtc($(event.target)),\\n                            productType: getPdpProductType(),\\n                            productSaleClearance: getPdpMiniPdpProductSaleClearance(event)\\n                        });\\n                    };\\n\\n                    $body\\n                        .on('click', '.buybox #add-to-cart,.buybox #add-to-cart-static,.stickybuybar #add-to-cart-sticky-buy-bar', callIfIsTrusted.bind(this, onPdpAtcClick))\\n                        .on('click', '.buybox #buy-now', callIfIsTrusted.bind(this, onPdpBuyNowClick))\\n                        .on('click', '.frequentlyboughtogether #addToCartBtn', callIfIsTrusted.bind(this, onFbtAtcClick));\\n                };\\n                const plpHandler = function () {\\n                    const onPlpTileClick = function (event) {\\n                        utils.sendCustomMboxEvent(basePlpTileClickEventName, {\\n                            productType: getPlpProductType(),\\n                            productSaleClearance: getPlpTileSaleClearanceType(event)\\n                        });\\n                    };\\n                    $body\\n                        .on('mouseup', '.productlistingpanel .nl-product__content', callIfIsTrusted.bind(this, onPlpTileClick))\\n                        .on('mouseup', '.productlistingpanel .nl-product__content .nl-product-card__atc-button', callIfIsTrusted.bind(this, onPlpOrCarouselTileAtcButtonClick.bind(this, atcTypes.plp)));\\n                };\\n                const flyerHandler = function () {\\n                    const onFlyerAtcClick = function (event) {\\n                        confirmAtcSendEvent(\\n                            'nl-toast__success-container',\\n                            atcTypes.flyer,\\n                            getDeliveryTypeOnByuboxOrMiniPdpAtc($(event.target)),\\n                            productTypes.na,\\n                            getPdpMiniPdpProductSaleClearance(event)\\n                        );\\n                    };\\n                    $body.on('click', '#add-to-cart', callIfIsTrusted.bind(this, onFlyerAtcClick));\\n                };\\n                const carouselAtcButtonExistsHandler = function () {\\n                    const setCarouselEventsResubscribe = function () {\\n                        console.log('[AB Test]: Attaching Event Listeners to Carousel Tiles');\\n\\n                        $('.nl-recommendations .swiper-wrapper:not(.ab-test-added-carousel-events-listeners)')\\n                            .addClass('ab-test-added-carousel-events-listeners')\\n                            .on('click', '.nl-product-card__atc-button', onPlpOrCarouselTileAtcButtonClick.bind(this, atcTypes.carousel));\\n\\n                        if (CSS.supports('selector(:not(a))')) {\\n                            utils\\n                                .waitForElement('.nl-recommendations .swiper-wrapper:not(.ab-test-added-carousel-events-listeners)')\\n                                .then(setCarouselEventsResubscribe);\\n                        }\\n                    };\\n\\n                    utils\\n                        .waitForElement('.nl-recommendations .swiper-wrapper:not(.ab-test-added-carousel-events-listeners)')\\n                        .then(setCarouselEventsResubscribe);\\n                };\\n\\n                const handlersRerPageType = {\\n                    'product': productHandler,\\n                    'plp': plpHandler,\\n                    'flyer': flyerHandler\\n                };\\n                \\n                try {\\n                    const currentPageType = document.querySelectorAll('.productlistingpanel').length > 0 \\n                        ? 'plp'\\n                        : document.getElementsByTagName('body').item(0).dataset.pagetype;\\n\\n                    if (!!handlersRerPageType[currentPageType] && typeof handlersRerPageType[currentPageType] === 'function') {\\n                        handlersRerPageType[currentPageType]();\\n                    }\\n                    utils\\n                        .waitForElement('.nl-recommendations .swiper-wrapper .nl-product-card__cta .nl-product-card__atc-button')\\n                        .then(carouselAtcButtonExistsHandler);\\n                } catch (error) {\\n                    console.log('[Target]: Error occurs while applying general tracking code: ' + error);\\n                }\\n            };\\n\\n            const utilsInterval = setInterval(() => {\\n                if (window.ab_test_utils) {\\n                    clearInterval(utilsInterval);\\n                    window.ab_test_utils.waitForJquery().then(function ($) {\\n                        $(document).ready(function () {\\n                            init(window.ab_test_utils, $);\\n                        });\\n                    });\\n                }\\n            }, 100);\\n        })();\\n    </script>\\n</div>\",\"selector\":\"BODY > *:eq(0)\",\"prehidingSelector\":\"\"}}]}],\"type\":\"personalization:decisions\",\"eventIndex\":0},{\"payload\":[{\"scope\":\"Target\",\"hint\":\"35\",\"ttlSeconds\":1800},{\"scope\":\"AAM\",\"hint\":\"9\",\"ttlSeconds\":1800},{\"scope\":\"EdgeNetwork\",\"hint\":\"or2\",\"ttlSeconds\":1800}],\"type\":\"locationHint:result\"},{\"payload\":[{\"key\":\"kndctr_A6C5776A5245B09C0A490D44_AdobeOrg_cluster\",\"value\":\"or2\",\"maxAge\":1800,\"attrs\":{\"SameSite\":\"None\"}},{\"key\":\"kndctr_A6C5776A5245B09C0A490D44_AdobeOrg_identity\",\"value\":\"CiY1NzUyMzc3NDcxOTAxOTc1MzU4NDA1Mzk3NzQ0OTU4ODg1MTk0MlISCIT7_cDLMxABGAEqA09SMjAA8AGE-_3AyzM=\",\"maxAge\":34128000,\"attrs\":{\"SameSite\":\"None\"}}],\"type\":\"state:store\"}]}"}, "redirectURL": "", "bodySize": 38359}, "time": 204.21899999998507, "cache": {}, "timings": {"blocked": 2.215999999989063, "connect": 57.244, "dns": 8.94, "receive": 2.0249999999890633, "send": 1.3359999999999985, "ssl": 24.842, "wait": 132.45800000000696, "_blocked_queueing": 2.0249999999890633}, "pageref": "E8C4D64DC2899A2ADAD2AB56C9886AF3", "_resourceType": "Fetch"}, 